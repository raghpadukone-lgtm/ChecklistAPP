<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexusOps | Corporate Checklist App</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <main class="app-container">
        <!-- Login / Setup Section -->
        <section id="login-section" class="glass-panel active">
            <div class="header">
                <span class="material-icons-round hero-icon">verified_user</span>
                <h1>Welcome to NexusOps</h1>
                <p>Digital Checklist Management</p>
            </div>
            
            <form id="login-form">
                <div class="input-group">
                    <label for="staff-name">Staff Name</label>
                    <input type="text" id="staff-name" placeholder="Enter your full name" required autocomplete="off">
                </div>
                <div class="input-group">
                    <label for="role-select">Primary Role</label>
                    <select id="role-select" required>
                        <option value="" disabled selected>Select your area</option>
                        <option value="arena-ops">Arena Operations</option>
                        <option value="reception">Reception & Ticketing</option>
                        <option value="manager">Duty Manager</option>
                    </select>
                </div>
                <button type="submit" class="btn primary-btn">
                    Access Checklists
                    <span class="material-icons-round">arrow_forward</span>
                </button>
            </form>
        </section>

        <!-- Dashboard Section -->
        <section id="dashboard-section" class="glass-panel hidden">
            <header class="dash-top">
                <div class="user-info">
                    <div class="avatar"><span id="user-initial">A</span></div>
                    <div>
                        <h2>Hello, <span id="display-name">Alex</span></h2>
                        <p class="role-text" id="display-role">Operations</p>
                    </div>
                </div>
                <button id="logout-btn" class="icon-btn" title="Sign Out">
                    <span class="material-icons-round">exit_to_app</span>
                </button>
            </header>

            <div class="task-summary">
                <div class="summary-card">
                    <h3>0</h3>
                    <p>Submitted Today</p>
                </div>
                <div class="summary-card highlight">
                    <h3 id="current-date">--/--/----</h3>
                    <p>Current Date</p>
                </div>
            </div>

            <h3 class="section-title">Available Checklists</h3>
            <div class="checklist-grid" id="checklist-grid">
                <!-- Dynamically populated based on role -->
            </div>
        </section>

        <!-- Active Checklist Section -->
        <section id="checklist-section" class="glass-panel hidden">
            <header class="dash-top">
                <button id="back-btn" class="icon-btn">
                    <span class="material-icons-round">arrow_back</span>
                </button>
                <div class="title-center">
                    <h2 id="checklist-title">Arena 1 Opening</h2>
                </div>
                <div class="spacer"></div>
            </header>

            <div class="progress-container">
                <div class="progress-text">
                    <span>Progress</span>
                    <span id="progress-percentage">0%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
            </div>

            <form id="checklist-form">
                <div class="tasks-list" id="tasks-list">
                    <!-- Tasks injected here -->
                </div>

                <div class="notes-group">
                    <label for="checklist-notes">Additional Remarks</label>
                    <textarea id="checklist-notes" placeholder="Any issues or observations..." rows="3"></textarea>
                </div>

                <button type="submit" class="btn success-btn" id="submit-checklist-btn" disabled>
                    Submit Checklist
                    <span class="material-icons-round">check_circle</span>
                </button>
            </form>
        </section>

        <!-- Success overlay -->
        <div id="success-overlay" class="overlay hidden">
            <div class="success-card glass-panel">
                <span class="material-icons-round success-icon">task_alt</span>
                <h2>Checklist Submitted!</h2>
                <p>Your record has been securely saved.</p>
                <button id="close-success-btn" class="btn primary-btn">Back to Dashboard</button>
            </div>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>
